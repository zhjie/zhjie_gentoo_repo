diff '--color=auto' -urpN 1/sound/drivers/Kconfig 2/sound/drivers/Kconfig
--- 1/sound/drivers/Kconfig	2025-12-03 08:18:41.192692130 -0000
+++ 2/sound/drivers/Kconfig	2025-12-03 08:20:22.136259754 -0000
@@ -1,4 +1,17 @@
 # SPDX-License-Identifier: GPL-2.0-only
+
+config ALSA_BRIDGE
+        tristate "Diretta ALSA driver"
+        default y
+        depends on SOUND && SND && CRC16
+        select SND_PCM
+
+config DIRETTA_DIRECT
+        tristate "Diretta Direct Stream driver"
+        default y
+        depends on SOUND && SND && CRC16
+        select SND_PCM
+
 config SND_MPU401_UART
 	tristate
 	select SND_RAWMIDI
diff '--color=auto' -urpN 1/sound/drivers/Makefile 2/sound/drivers/Makefile
--- 1/sound/drivers/Makefile	2025-12-03 08:18:36.109713902 -0000
+++ 2/sound/drivers/Makefile	2025-12-03 08:21:45.418903025 -0000
@@ -3,6 +3,10 @@
 # Makefile for ALSA
 # Copyright (c) 2001 by Jaroslav Kysela <perex@perex.cz>
 #
+alsa_bridge := alda_bridge.o
+diretta_direct := diretta_direct.o
+obj-$(CONFIG_ALSA_BRIDGE) += alsa_bridge.o
+obj-$(CONFIG_DIRETTA_DIRECT) += diretta_direct.o

 snd-dummy-y := dummy.o
 snd-aloop-y := aloop.o
